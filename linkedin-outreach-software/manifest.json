{
  "manifest_version": 3,
  "name": "LinkedIn Outreach Software",
  "short_name": "LI Outreach",
  "description": "AI-powered LinkedIn outreach tool — find contact info, draft tailored messages, and manage leads with zero limitations.",
  "version": "1.0.0",
  "minimum_chrome_version": "116",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "LinkedIn Outreach",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },

  "side_panel": {
    "default_path": "sidebar.html"
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "sidePanel",
    "scripting",
    "contextMenus"
  ],

  "host_permissions": [
    "https://*.linkedin.com/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://*.linkedin.com/*"],
      "js": ["lib/utils.js", "lib/profile-scraper.js", "lib/contact-finder.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["sidebar.html", "icons/*", "lib/*"],
      "matches": ["https://*.linkedin.com/*"]
    }
  ]
}
